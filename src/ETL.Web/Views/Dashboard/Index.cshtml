@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4 app-hero">
    <div>
        <h1 class="h3 mb-1">ETL Dashboard</h1>
        <p class="text-muted mb-0">Operational overview of your ETL pipelines.</p>
    </div>
    <a asp-controller="EtlJobs" asp-action="Create" class="btn btn-primary">Create ETL Job</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Total Jobs</div>
                <div class="display-6">@Model.TotalJobs</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Active Jobs</div>
                <div class="display-6">@Model.ActiveJobs</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Successful Runs</div>
                <div class="display-6 text-success">@Model.SuccessfulRuns</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Failed Runs</div>
                <div class="display-6 text-danger">@Model.FailedRuns</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white">
        <h2 class="h5 mb-0">Recent Runs</h2>
    </div>
    <div class="card-body p-0">
        @if (!Model.RecentRuns.Any())
        {
            <div class="p-4 text-muted">No run history found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                    <tr>
                        <th>Job</th>
                        <th>Status</th>
                        <th>Started (UTC)</th>
                        <th>Completed (UTC)</th>
                        <th>Loaded</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var run in Model.RecentRuns)
                    {
                        <tr>
                            <td>
                                <a asp-controller="EtlJobs" asp-action="Details" asp-route-id="@run.JobId">@run.JobName</a>
                            </td>
                            <td>
                                <span class="badge @(run.Status == "Succeeded" ? "bg-success" : run.Status == "Failed" ? "bg-danger" : "bg-secondary")">@run.Status</span>
                            </td>
                            <td>@run.StartedAtUtc.ToString("u")</td>
                            <td>@(run.CompletedAtUtc?.ToString("u") ?? "-")</td>
                            <td>@run.RecordsLoaded</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@model EtlJobUpsertViewModel
@{
    ViewData["Title"] = "Create ETL Job";
    if (!Model.FieldMappings.Any())
    {
        Model.FieldMappings.Add(new FieldMappingInputViewModel { Order = 0 });
    }
}

<h1 class="h3 mb-3">Create ETL Job</h1>

<form asp-action="Create" method="post" id="etlJobForm">
    @Html.AntiForgeryToken()
    <partial name="_JobForm" model="Model" />

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save Job</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/etl-job-form.js" asp-append-version="true"></script>
    <script src="~/js/etl-config-help.js" asp-append-version="true"></script>
}

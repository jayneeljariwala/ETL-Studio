@model EtlJobRunHistoryViewModel
@{
    ViewData["Title"] = "Job Logs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Error Logs</h1>
        <p class="text-muted mb-0">Recent failed runs for this job.</p>
    </div>
    <a asp-action="Details" asp-route-id="@Model.JobId" class="btn btn-outline-secondary">Back to Details</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (!Model.Runs.Any())
        {
            <div class="p-4 text-muted">No failed runs found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                    <tr>
                        <th>Started (UTC)</th>
                        <th>Completed (UTC)</th>
                        <th>Error</th>
                        <th>Read</th>
                        <th>Failed</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var run in Model.Runs)
                    {
                        <tr>
                            <td>@run.StartedAtUtc.ToString("u")</td>
                            <td>@(run.CompletedAtUtc?.ToString("u") ?? "-")</td>
                            <td class="text-danger">@(run.ErrorMessage ?? "-")</td>
                            <td>@run.RecordsRead</td>
                            <td>@run.RecordsFailed</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
